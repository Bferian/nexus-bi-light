{
  "name": "nexus-bi-light",
  "version": "1.0.0",
  "description": "Nexus BI Light — Analise Empresarial",
  "main": "electron/main.js",
  "scripts": {
    "build": "echo 'no build needed'",
    "electron:build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^32.2.6",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.nexusbi.light",
    "productName": "Nexus BI Light",
    "directories": { "output": "dist-electron" },
    "files": [
      "electron/**/*",
      "nexus-bi-light.html",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
